<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Save Button -->
        <Button
            android:id="@+id/save_button_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save"
            style="@style/Widget.Material3.Button"
            android:layout_marginBottom="16dp"/>

        <!-- Processing Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/processing_section"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/raw_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/raw_mode"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/target_language_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/target_language"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/target_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/target_language_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/target_language_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorTertiary"
            android:layout_marginStart="4dp"
            android:layout_marginTop="-12dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/manage_custom_languages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/manage_custom_languages"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Prompts Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prompts_section"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"/>

        <!-- User Prompt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/user_prompt_template"
                android:textAppearance="?attr/textAppearanceSubtitle1"/>
            <Button
                android:id="@+id/reset_user_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_prompt"
                style="@style/Widget.Material3.Button.TextButton"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prompt_variables"
            android:textAppearance="?attr/textAppearanceCaption"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/user_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Translate Prompt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/translate_prompt"
                android:textAppearance="?attr/textAppearanceSubtitle1"/>
            <Button
                android:id="@+id/reset_translate_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_prompt"
                style="@style/Widget.Material3.Button.TextButton"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prompt_variables"
            android:textAppearance="?attr/textAppearanceCaption"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/translate_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- System Prompt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/system_prompt"
                android:textAppearance="?attr/textAppearanceSubtitle1"/>
            <Button
                android:id="@+id/reset_system_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_prompt"
                style="@style/Widget.Material3.Button.TextButton"
                android:textSize="12sp"/>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/system_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Restore All Prompts Button -->
        <Button
            android:id="@+id/restore_defaults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/restore_defaults"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- LLM Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/llm_section"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/llm_provider_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/provider"
            android:layout_marginBottom="8dp">

            <AutoCompleteTextView
                android:id="@+id/llm_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/llm_url_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_url"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/llm_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/llm_token_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_token"
            android:layout_marginBottom="4dp"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/llm_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/fetch_llm_models"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fetch_models"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/test_llm_token"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_token"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/llm_model_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/model"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/llm_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- STT Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stt_section"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/stt_provider_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/provider"
            android:layout_marginBottom="8dp">

            <AutoCompleteTextView
                android:id="@+id/stt_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/stt_url_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_url"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/stt_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/stt_token_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_token"
            android:layout_marginBottom="4dp"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/stt_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/validate_stt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/validate_fetch"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/stt_model_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/model"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/stt_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Recognition Service Setup -->
        <Button
            android:id="@+id/set_recognition_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/set_recognition_service"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="16dp"/>

        <!-- Bottom Save Button -->
        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save"
            style="@style/Widget.Material3.Button"
            android:layout_marginBottom="24dp"/>

        <!-- About Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/about_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorTertiary"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/about_commit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorTertiary"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/about_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_input_info_message"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorTertiary"
            android:clickable="true"
            android:focusable="true"
            android:autoLink="web"
            android:padding="4dp"
            android:layout_marginStart="-4dp"/>

    </LinearLayout>
</ScrollView>
